--- !u!114 &519332974
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 519332973}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 8b98ac074b86e14499be3d07766c1b96, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::NarratorController
  targetSceneName: Prison_Scene
  playOnlyOncePerSession: 1
  voiceSource: {fileID: 519332976}
  bgSource: {fileID: 264677738}
  introBg: {fileID: 8300000, guid: 1f6b145ca8db9c543a6489bb5dc7bce9, type: 3}
  logoSound: {fileID: 8300000, guid: 5860ed7b065ab4740917182715876f1d, type: 3}
  sentenceSequence:
  - sentence: Ah,
    clip: {fileID: 8300000, guid: 8d1ce71a8f8ac634f8cd9574e3fff4de, type: 3}
  - sentence: another sinful soul.
    clip: {fileID: 8300000, guid: 9be4b42c3a5cf6843926f3e71f881e3e, type: 3}
  - sentence: Welcome.
    clip: {fileID: 8300000, guid: c5f34c6c275c4c346bef59bcf248f7e1, type: 3}
  - sentence: I am the one who gathers those who fall,
    clip: {fileID: 8300000, guid: 3ae41099da9f2444ea454a8d8ca3f377, type: 3}
  - sentence: to piece them back together.
    clip: {fileID: 8300000, guid: db22f05905583e74cb3340d1fb4e5736, type: 3}
  - sentence: 'I am the one who guides lost sinners to their second chance. '
    clip: {fileID: 8300000, guid: 548e56a4abf22b24bb5433a19ac98cbc, type: 3}
  - sentence: I am the one who watches,
    clip: {fileID: 8300000, guid: d16bb08d430246d4785ac52ff52688a8, type: 3}
  - sentence: but never interferes.
    clip: {fileID: 8300000, guid: d44df0716e03ded4e8916ee17881d8db, type: 3}
  - sentence: I am known as simply,
    clip: {fileID: 8300000, guid: b56617a5c0112aa4aa6008e42b84e888, type: 3}
  - sentence: the Keeper.
    clip: {fileID: 8300000, guid: 5a6d8c351892cbf4ab8574b3e3e50f4f, type: 3}
  - sentence: If you truly wish it,
    clip: {fileID: 8300000, guid: f2ae3509a2793eb4b91ced3e855869e9, type: 3}
  - sentence: you may yet escape your eternal torment
    clip: {fileID: 8300000, guid: fe907acc07feeb84698fa4cfcedcb106, type: 3}
  - sentence: by proving your redemption.
    clip: {fileID: 8300000, guid: fe66158b43964644f9644ac6fb8fd17f, type: 3}
  - sentence: Climb the tower,
    clip: {fileID: 8300000, guid: fca3bf1bf7d77c84ca1a6876829fa763, type: 3}
  - sentence: overcome the weight of humanity's greatest flaws
    clip: {fileID: 8300000, guid: 4d5f05537c2ca4f49850f4dbd3e9ffed, type: 3}
  - sentence: and cleanse your sins
    clip: {fileID: 8300000, guid: d95372489a2f400429930f4177c87998, type: 3}
  - sentence: in the blood of the climb.
    clip: {fileID: 8300000, guid: 148c2cf3117b6214fa5a34a60af80ba0, type: 3}
  - sentence: Only then shall you leave this place.
    clip: {fileID: 8300000, guid: ba5c247c70734e5418476255dbacc035, type: 3}
  afterIntroClip: {fileID: 8300000, guid: c92d7639529389746b27e0d657edcd92, type: 3}
  finalClip: {fileID: 8300000, guid: 75114c4c55ec3094f86687627446f41c, type: 3}
  afterIntroVolume: 1
  finalClipVolume: 1
